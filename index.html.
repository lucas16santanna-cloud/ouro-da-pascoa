<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Receitas de Ovos de Páscoa - Lucro na Páscoa</title>
    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Fontes Google -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body { font-family: 'Montserrat', sans-serif; scroll-behavior: smooth; }
        .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; }
        .faq-item.active .faq-content { max-height: 200px; }
        .faq-item.active .chevron { transform: rotate(180deg); }
    </style>
</head>
<body class="bg-[#fdfaf6] text-[#2d1b1a]">

    <!-- Top Banner -->
    <div class="bg-[#d4af37] text-white text-center py-2 text-xs md:text-sm font-bold uppercase tracking-widest w-full shadow-sm">
        🔥 Oferta limitada (somente hoje)
    </div>

    <!-- Hero Section -->
    <section class="min-h-screen flex items-center justify-center py-20 bg-white">
        <div class="container mx-auto px-4 text-center">
            <span class="inline-block px-4 py-1 mb-8 rounded-full bg-[#d4af37] text-white text-sm font-bold tracking-wider uppercase">
                Páscoa 2026: Sua Oportunidade de Ouro
            </span>
            
            <div class="relative mb-12 inline-block">
                <img src="https://i.imgur.com/SPKqFIw.png" alt="E-book" class="w-full max-w-sm md:max-w-md rounded-2xl shadow-2xl mx-auto">
                <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-4/5 h-4 bg-black/20 blur-xl rounded-[100%]"></div>
            </div>

            <div class="max-w-4xl mx-auto">
                <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-[#2d1b1a] mb-6 leading-tight">
                    Receitas de <span class="text-[#d4af37]">Ovos de Páscoa Personalizados</span>
                </h1>
                <p class="text-xl md:text-2xl text-gray-600 mb-8 font-light">
                    O Cardápio de Páscoa Completo com <span class="font-bold text-[#2d1b1a]">Recheios Criativos</span>.<br>
                    Fature de R$ 2.000 a R$ 5.000 em apenas 15 dias.
                </p>
                
                <button onclick="document.getElementById('offer').scrollIntoView({behavior:'smooth'})" class="bg-[#d4af37] hover:bg-[#b8962e] text-white px-10 py-5 rounded-full text-xl font-bold inline-flex items-center gap-2 transition-all transform hover:scale-105">
                    QUERO COMEÇAR A LUCRAR AGORA!
                    <i data-lucide="arrow-right"></i>
                </button>
                <div class="flex items-center justify-center gap-2 text-gray-500 text-sm mt-6">
                    <i data-lucide="shield-check" class="text-[#27ae60]"></i>
                    <span>Garantia de 7 dias</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Benefícios -->
    <section class="py-24 bg-white">
        <div class="container mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-bold mb-4">Por que este é o melhor negócio?</h2>
                <div class="w-24 h-1 bg-[#d4af37] mx-auto"></div>
            </div>
            <div class="grid md:grid-cols-3 lg:grid-cols-5 gap-8">
                <div class="p-6 rounded-2xl bg-[#fdfaf6] border-2 border-[#d4af37] text-center">
                    <i data-lucide="dollar-sign" class="mx-auto mb-4 text-[#d4af37]"></i>
                    <h3 class="font-bold mb-2">Baixo Investimento</h3>
                    <p class="text-sm text-gray-600">Use o que já tem na sua cozinha.</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#fdfaf6] border-2 border-[#d4af37] text-center">
                    <i data-lucide="trending-up" class="mx-auto mb-4 text-[#d4af37]"></i>
                    <h3 class="font-bold mb-2">Lucro Imediato</h3>
                    <p class="text-sm text-gray-600">Margens de mais de 200%.</p>
                </div>
                <!-- Adicione os outros itens aqui se desejar -->
            </div>
        </div>
    </section>

    <!-- Oferta -->
    <section id="offer" class="py-24 bg-[#fdfaf6]">
        <div class="container mx-auto px-4 text-center">
            <div class="max-w-3xl mx-auto bg-white p-12 rounded-[3rem] shadow-xl border border-[#eee]">
                <i data-lucide="shield-check" class="w-20 h-20 text-[#27ae60] mx-auto mb-6"></i>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Risco Zero para Você!</h2>
                <p class="text-gray-600 mb-8">7 dias de garantia incondicional.</p>
                
                <div class="mb-10">
                    <p class="text-gray-400 line-through text-xl">De R$ 97,00</p>
                    <div class="flex items-baseline justify-center gap-1">
                        <span class="text-3xl font-bold text-[#d4af37]">R$</span>
                        <span class="text-7xl md:text-8xl font-black text-[#d4af37]">29,90</span>
                    </div>
                </div>

                <button class="w-full bg-[#2ecc71] hover:bg-[#27ae60] text-white py-6 rounded-2xl text-2xl font-black shadow-lg transition-all">
                    QUERO MINHA RENDA EXTRA AGORA
                </button>

                <div class="mt-10 pt-8 border-t border-[#eee] flex flex-col items-center gap-4">
                    <p class="text-xs font-bold text-gray-400 uppercase">Pagamento Seguro</p>
                    <div class="flex gap-6 opacity-50">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5e/Visa_Inc._logo.svg/2560px-Visa_Inc._logo.svg.png" class="h-4">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/a/a2/Logo_Pix_Brasil.png/1200px-Logo_Pix_Brasil.png" class="h-6">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="py-12 bg-[#2d1b1a] text-white/40 text-center text-sm">
        <p>© 2026 Receitas de Ovos de Páscoa. Todos os direitos reservados.</p>
    </footer>

    <script>
        // Inicializa os ícones
        lucide.createIcons();

        // Lógica simples de FAQ (se você adicionar a seção de FAQ no HTML acima)
        function toggleFaq(index) {
            const items = document.querySelectorAll('.faq-item');
            items[index].classList.toggle('active');
        }
    </script>
</body>
</html>
